# --- Pedidos em SQLite (grátis, ficheiro local; Node.js 22.5+) ---
# Sem isto, pedidos ficam em store.json como antes.
# USE_SQLITE=1
# Caminho opcional do ficheiro .db (omissão: server/data/guiame.db)
# SQLITE_PATH=

# Produção (exemplo) — SMS real (Twilio)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+1234567890
# Opcional: omitir devCode no JSON após envio bem-sucedido (ou forçar sempre): 1 = nunca devolver devCode
# TWILIO_HIDE_DEVCODE=1

# --- KYC (integração futura; ver KYC-INTEGRACAO.md na raiz app-servico) ---
# KYC_MODE=local
# KYC_MODE=provider
# KYC_STRICT=1
# KYC_PUBLIC_ENV=production
# KYC_PROVIDER_SLUG=
# KYC_WEBHOOK_SECRET=

# Login com Google (Google Cloud Console → OAuth 2.0 → ID do cliente Web)
# Origens JavaScript autorizadas: http://localhost:3333 e https://SEU-APP.onrender.com
# GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com

# Desenvolvimento: ignorar validação OTP no servidor (não usar em produção)
# SKIP_OTP=1

# --- Taxa de aceite (US$ 5 → BRL, arredondado para cima) ---
# Câmbio fixo opcional (omissão: API AwesomeAPI USD-BRL)
# FX_USD_BRL=5.90
# Saldo inicial simulado para novos clientes (dev)
# CLIENTE_SALDO_INICIAL_DEV=100
# Saldo inicial simulado para novos prestadores (dev; taxa US$ 10 no fechamento)
# PRESTADOR_SALDO_INICIAL_DEV=150
